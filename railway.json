{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "startCommand": "python manage.py migrate --noinput && gunicorn divsystem.wsgi:application --bind 0.0.0.0:$PORT --workers 3 --timeout 60 --access-logfile -",
    "healthcheckPath": "/api/v1/agent/ping",
    "healthcheckTimeout": 30,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
